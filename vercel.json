{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.cardmax.com.mx"
        }
      ],
      "destination": "https://cardmax.com.mx/:path*",
      "permanent": true
    },
    {
      "source": "/tarjetas-nfc.html",
      "destination": "/tarjetas-chip-nfc.html",
      "permanent": true
    },
    {
      "source": "/credenciales-pvc.html",
      "destination": "/tarjetas-pvc.html",
      "permanent": true
    },
    {
      "source": "/resenas.html",
      "destination": "/rese%C3%B1as.html",
      "permanent": true
    }
  ]
}
